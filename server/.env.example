# ==== 服务端基础配置 ====
NODE_ENV=development
PORT=3001
GLOBAL_PREFIX=v1

# ==== 数据库 ====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhuoqiu_dev?schema=public"

# ==== JWT ====
JWT_ACCESS_SECRET=change-me-to-random-secret-access
JWT_REFRESH_SECRET=change-me-to-random-secret-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ==== 初始 super_admin（仅 seed 时生效） ====
SEED_SUPER_ADMIN_USERNAME=admin
SEED_SUPER_ADMIN_PASSWORD=Admin@123456
SEED_SUPER_ADMIN_NAME=超级管理员

# ==== 微信小程序（批次 2 前可以空）====
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# ==== 抖音小程序（批次 2 前可以空）====
DOUYIN_MP_APP_ID=
DOUYIN_MP_APP_SECRET=

# ==== 腾讯地图 WebService（v2.21「附近按城市」用）====
# 申请：https://lbs.qq.com/dev/console/key/manage
# key 在控制台启用 WebServiceAPI，并选「签名校验」鉴权方式，会拿到一个 SK。
# 留空 → /v1/geo/resolve-city 直接返回 city: null（前端会降级到手选城市）
TENCENT_MAP_KEY=
TENCENT_MAP_SK=

# ==== 本地调试：写死验证码（生产留空！）====
# 设置后所有 send-sms 跳过限流和持久化；verify 仅接受这个值
DEV_FIXED_SMS_CODE=123456
