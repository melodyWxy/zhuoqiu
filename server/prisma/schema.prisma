// 桌球计分 · 二期批次 1 · 共享比赛 Prisma schema
// 对应设计稿 ux/v2/shared-match-backend.md §4

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户相关（C 端）
// ============================================================

enum UserStatus {
  active
  banned
  deleted
}

enum PrimarySource {
  wechat
  douyin
  phone
}

model User {
  id             String         @id // u_xxxxxxxx
  phoneNumber    String?        @unique @map("phone_number") @db.VarChar(20)
  nickname       String         @db.VarChar(32)
  avatar         String         @default("🎱") @db.VarChar(32)
  primarySource  PrimarySource  @map("primary_source")
  status         UserStatus     @default(active)
  banUntil       DateTime?      @map("ban_until")
  banReason      String?        @map("ban_reason")
  lastActiveAt   DateTime?      @map("last_active_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  wechatBindings WechatBinding[]
  douyinBindings DouyinBinding[]
  ownedMatches   Match[]         @relation("OwnerMatches")
  seatOccupancies MatchPlayer[]
  authoredEvents  MatchEvent[]

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model WechatBinding {
  id          String    @id
  userId      String    @map("user_id")
  openId      String    @map("open_id") @db.VarChar(128)
  unionId     String?   @map("union_id") @db.VarChar(128)
  mpAppId     String    @map("mp_app_id") @db.VarChar(64)
  bindAt      DateTime  @map("bind_at") @default(now())
  unboundAt   DateTime? @map("unbound_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mpAppId, openId])
  @@index([unionId])
  @@index([userId])
  @@map("wechat_bindings")
}

model DouyinBinding {
  id          String    @id
  userId      String    @map("user_id")
  openId      String    @map("open_id") @db.VarChar(128)
  unionId     String?   @map("union_id") @db.VarChar(128)
  mpAppId     String    @map("mp_app_id") @db.VarChar(64)
  bindAt      DateTime  @map("bind_at") @default(now())
  unboundAt   DateTime? @map("unbound_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mpAppId, openId])
  @@index([unionId])
  @@index([userId])
  @@map("douyin_bindings")
}

enum PhoneCodePurpose {
  login
  bind
  merge
  venue_login
}

model PhoneVerifyCode {
  id           BigInt           @id @default(autoincrement())
  phoneNumber  String           @map("phone_number") @db.VarChar(20)
  code         String           @db.VarChar(8)
  purpose      PhoneCodePurpose
  expiresAt    DateTime         @map("expires_at")
  usedAt       DateTime?        @map("used_at")
  attempts     Int              @default(0)
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([phoneNumber, purpose, expiresAt])
  @@map("phone_verify_codes")
}

// ============================================================
// 管理端账号
// ============================================================

enum AdminRole {
  super_admin
  operator
  readonly
}

enum AdminStatus {
  active
  inactive
}

model AdminAccount {
  id                   String      @id // a_xxxxxxxx
  username             String      @unique @db.VarChar(32)
  name                 String      @db.VarChar(64)
  passwordHash         String      @map("password_hash") @db.VarChar(255)
  role                 AdminRole
  status               AdminStatus @default(active)
  mustChangePassword   Boolean     @default(false) @map("must_change_password")
  lastLoginAt          DateTime?   @map("last_login_at")
  lastLoginIp          String?     @map("last_login_ip") @db.VarChar(45)
  failedLoginCount     Int         @default(0) @map("failed_login_count")
  lockedUntil          DateTime?   @map("locked_until")
  notes                String?     @db.Text
  createdBy            String?     @map("created_by")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  auditLogs AdminAuditLog[]

  @@index([role])
  @@map("admin_accounts")
}

// ============================================================
// 比赛相关
// ============================================================

enum MatchType {
  nine_ball
  eight_ball
}

enum MatchState {
  waiting
  in_progress
  paused
  ended
  dissolved
}

model Match {
  id                  String      @id // m_xxxxxxxx
  code                String?     @unique @db.VarChar(6) // 6 位房间码，已结束 24h 后置空
  ownerUserId         String      @map("owner_user_id")
  type                MatchType
  rulesJson           Json        @map("rules_json")
  state               MatchState  @default(waiting)
  timerStartedAt      DateTime?   @map("timer_started_at")
  timerAccumulatedMs  BigInt      @default(0) @map("timer_accumulated_ms")
  isPaused            Boolean     @default(false) @map("is_paused")
  lastEventAt         DateTime?   @map("last_event_at")
  endedAt             DateTime?   @map("ended_at")
  endedBy             String?     @map("ended_by") @db.VarChar(32)
  endedReason         String?     @map("ended_reason") @db.VarChar(255)
  eventId             String?     @map("event_id") @db.VarChar(32) // 赛事关联（批次 3 预留）
  bracketNodeId       String?     @map("bracket_node_id") @db.VarChar(64)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  owner   User         @relation("OwnerMatches", fields: [ownerUserId], references: [id])
  players MatchPlayer[]
  events  MatchEvent[]

  @@index([state])
  @@index([ownerUserId])
  @@index([createdAt])
  @@map("matches")
}

model MatchPlayer {
  id           BigInt    @id @default(autoincrement())
  matchId      String    @map("match_id")
  slot         Int       @db.SmallInt
  displayName  String    @map("display_name") @db.VarChar(32)
  userId       String?   @map("user_id")
  joinedAt     DateTime  @map("joined_at") @default(now())
  leftAt       DateTime? @map("left_at")
  isCurrent    Boolean   @default(true) @map("is_current")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([matchId, slot])
  @@index([userId])
  @@map("match_players")
}

model MatchEvent {
  id                 BigInt    @id @default(autoincrement())
  matchId            String    @map("match_id")
  serverSeq          BigInt    @map("server_seq")
  clientSeq          BigInt?   @map("client_seq")
  actorUserId        String?   @map("actor_user_id")
  actorAdminId       String?   @map("actor_admin_id")
  type               String    @db.VarChar(32) // 见设计稿 §4.4.4
  payloadJson        Json      @map("payload_json")
  undone             Boolean   @default(false)
  undoneByEventId    BigInt?   @map("undone_by_event_id")
  createdAt          DateTime  @default(now()) @map("created_at")

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [actorUserId], references: [id])

  @@unique([matchId, serverSeq])
  @@index([matchId, createdAt])
  @@index([actorUserId])
  @@map("match_events")
}

// ============================================================
// 审计 & 系统设置
// ============================================================

model AdminAuditLog {
  id             BigInt   @id @default(autoincrement())
  actorAdminId   String   @map("actor_admin_id")
  action         String   @db.VarChar(64)
  targetType     String?  @map("target_type") @db.VarChar(32)
  targetId       String?  @map("target_id") @db.VarChar(64)
  detailJson     Json     @map("detail_json")
  ip             String   @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")

  actor AdminAccount @relation(fields: [actorAdminId], references: [id])

  @@index([actorAdminId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model SystemSetting {
  key        String    @id @db.VarChar(64)
  valueJson  Json      @map("value_json")
  updatedBy  String?   @map("updated_by")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================================
// 球房（商家）相关 · v2.10
// ============================================================

enum VenueAccountRole {
  owner
  staff
}

enum VenueAccountStatus {
  active
  banned
}

enum VenueStatus {
  active
  suspended
}

enum VenueApplicationStatus {
  draft
  pending
  approved
  rejected
}

enum VenueApplicationSource {
  c_app
  admin_web
}

model VenueAccount {
  id             String              @id // va_xxxxxxxx
  phoneNumber    String              @unique @map("phone_number") @db.VarChar(20)
  nickname       String              @db.VarChar(32)
  role           VenueAccountRole    @default(owner)
  venueId        String?             @map("venue_id") // owner 可以 null（等 venue 创建后回填），staff 必填
  status         VenueAccountStatus  @default(active)
  lastLoginAt    DateTime?           @map("last_login_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  venue          Venue?              @relation("VenueStaff", fields: [venueId], references: [id])
  ownedVenue     Venue?              @relation("VenueOwner")
  applications   VenueApplication[]  @relation("VenueApplicationApplicant")

  @@index([status])
  @@map("venue_accounts")
}

model Venue {
  id              String        @id // v_xxxxxxxx
  name            String        @db.VarChar(128)
  slug            String?       @unique @db.VarChar(64)
  address         String        @db.VarChar(255)
  lat             Float?
  lng             Float?
  phone           String        @db.VarChar(32)
  coverImage      String?       @map("cover_image") @db.VarChar(512)
  tablesCount     Int           @default(0) @map("tables_count") @db.SmallInt
  openHoursJson   Json?         @map("open_hours_json")
  description     String?       @db.Text

  ownerAccountId  String        @unique @map("owner_account_id")
  owner           VenueAccount  @relation("VenueOwner", fields: [ownerAccountId], references: [id])
  staff           VenueAccount[] @relation("VenueStaff")

  status          VenueStatus   @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@map("venues")
}

model VenueApplication {
  id                 String                  @id // app_xxxxxxxx
  applicantAccountId String                  @map("applicant_account_id")
  applicant          VenueAccount            @relation("VenueApplicationApplicant", fields: [applicantAccountId], references: [id])

  source             VenueApplicationSource  @default(admin_web)
  payloadJson        Json                    @map("payload_json")
  licenseImage       String?                 @map("license_image") @db.VarChar(512)
  idCardImage        String?                 @map("id_card_image") @db.VarChar(512)

  status             VenueApplicationStatus  @default(draft)
  rejectReason       String?                 @map("reject_reason") @db.Text
  reviewedByAdminId  String?                 @map("reviewed_by_admin_id")
  reviewedAt         DateTime?               @map("reviewed_at")
  venueId            String?                 @map("venue_id")

  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  @@index([applicantAccountId])
  @@index([status])
  @@index([createdAt])
  @@map("venue_applications")
}

// ============================================================
// 赛事 · v2.10
// ============================================================

enum TournamentFormat {
  single_elim
  double_elim
  round_robin
  swiss
}

enum TournamentStatus {
  draft
  registering
  registration_closed
  in_progress
  completed
  cancelled
}

enum TournamentRegistrationStatus {
  confirmed
  withdrawn
  disqualified
}

enum BracketMatchStatus {
  pending
  ready
  in_progress
  completed
  walkover
}

model Tournament {
  id                    String           @id // t_xxxxxxxx
  venueId               String           @map("venue_id")

  title                 String           @db.VarChar(128)
  gameType              MatchType        @map("game_type")
  format                TournamentFormat @default(single_elim)
  rulesJson             Json             @map("rules_json")
  maxPlayers            Int              @map("max_players") @db.SmallInt
  minPlayers            Int              @default(4) @map("min_players") @db.SmallInt
  entryFeeCents         Int              @default(0) @map("entry_fee_cents")
  prizePoolText         String?          @map("prize_pool_text") @db.Text
  registrationStartsAt  DateTime         @map("registration_starts_at")
  registrationEndsAt    DateTime         @map("registration_ends_at")
  matchStartsAt         DateTime         @map("match_starts_at")
  coverImage            String?          @map("cover_image") @db.VarChar(512)
  noticeText            String?          @map("notice_text") @db.Text

  status                TournamentStatus @default(draft)
  createdByAccountId    String           @map("created_by_account_id")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  registrations         TournamentRegistration[]
  bracketMatches        TournamentBracketMatch[]

  @@index([venueId, status])
  @@index([status, registrationEndsAt])
  @@index([createdByAccountId])
  @@map("tournaments")
}

model TournamentRegistration {
  id             String                       @id // reg_xxxxxxxx
  tournamentId   String                       @map("tournament_id")
  tournament     Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  userId         String                       @map("user_id")
  displayName    String                       @map("display_name") @db.VarChar(32)
  phone          String                       @db.VarChar(20)

  seed           Int?                         @db.SmallInt
  status         TournamentRegistrationStatus @default(confirmed)
  registeredAt   DateTime                     @default(now()) @map("registered_at")

  bracketEntriesA TournamentBracketMatch[]    @relation("BracketPlayerA")
  bracketEntriesB TournamentBracketMatch[]    @relation("BracketPlayerB")
  bracketWins     TournamentBracketMatch[]    @relation("BracketWinner")

  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId, status])
  @@map("tournament_registrations")
}

model TournamentBracketMatch {
  id                       String              @id // bm_xxxxxxxx
  tournamentId             String              @map("tournament_id")
  tournament               Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  round                    Int                 @db.SmallInt
  slotInRound              Int                 @map("slot_in_round") @db.SmallInt

  playerARegistrationId    String?             @map("player_a_registration_id")
  playerA                  TournamentRegistration? @relation("BracketPlayerA", fields: [playerARegistrationId], references: [id])
  playerBRegistrationId    String?             @map("player_b_registration_id")
  playerB                  TournamentRegistration? @relation("BracketPlayerB", fields: [playerBRegistrationId], references: [id])

  matchId                  String?             @unique @map("match_id")
  winnerRegistrationId     String?             @map("winner_registration_id")
  winner                   TournamentRegistration? @relation("BracketWinner", fields: [winnerRegistrationId], references: [id])

  status                   BracketMatchStatus  @default(pending)
  scheduledAt              DateTime?           @map("scheduled_at")

  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  @@unique([tournamentId, round, slotInRound])
  @@index([tournamentId, round])
  @@map("tournament_bracket_matches")
}
