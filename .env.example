# ========================================================
# 桌球计分 · 部署配置
# 复制为 .env 后修改：cp .env.example .env
# ========================================================

# ----- 端口（宿主机暴露） -----
# 默认部署不暴露这三个端口：流量统一走 caddy 容器（80/443）
# 需要 LAN 直连调试时，在 docker-compose.yml 取消对应 ports 块的注释，再用这里的值
H5_PORT=8080
ADMIN_PORT=8081
API_PORT=3009

# ----- 域名（仅用于文档展示；nginx 用 default_server 不绑定具体域名） -----
# 配反向代理（Caddy / Nginx / 阿里云 SLB）时把下面三个域名分别指向上面的端口
H5_DOMAIN=billiards-client.macrobit.com.cn
ADMIN_DOMAIN=billiards-admin.macrobit.com.cn
API_DOMAIN=billiards-server.macrobit.com.cn

# ----- CORS 来源白名单 -----
# 拆 API 域名部署（前端域名 ≠ API 域名）时必须配。逗号分隔，无空格。
# 留空 / "*" → 允许任意 origin（同源部署 / dev 用）
CORS_ORIGINS=https://billiards-client.macrobit.com.cn,https://billiards-admin.macrobit.com.cn

# ----- PostgreSQL（容器内，无需对外暴露） -----
POSTGRES_DB=zhuoqiu
POSTGRES_USER=zhuoqiu
POSTGRES_PASSWORD=zhuoqiu_dev_change_me

# ----- JWT secrets（先 dev 默认；上线改 32+ 随机字符串） -----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- 开发模式短信 -----
# 设了就跳过真实短信通道，所有 send-sms 直接通过，verify 只接受这个值
# 上线前清空（DEV_FIXED_SMS_CODE=）让真实短信通道生效
DEV_FIXED_SMS_CODE=123456

# ----- 默认平台超级管理员（首次启动 seed 时创建） -----
SEED_SUPER_ADMIN_USERNAME=admin
SEED_SUPER_ADMIN_PASSWORD=Admin@123456
SEED_SUPER_ADMIN_NAME=超级管理员

# ----- 默认开发用商家账号 -----
SEED_DEV_VENUE_PHONE=13900000001

# ----- 阿里云 OSS（存商家上传的营业执照 / 封面图等）-----
# OSS_ENABLED=true 时走 OSS，否则回落到 server 本地 uploads/ 卷
OSS_ENABLED=false
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# 可选：自定义域名（CNAME 到 OSS）。不填则用 <bucket>.<region>.aliyuncs.com
OSS_ENDPOINT=
# 可选：给 STS 临时凭证（后续客户端直传用）；服务端代传模式用不到
OSS_ROLE_ARN=

# ----- 腾讯位置服务（省市区行政区划树：发现球房 / 球房入驻地区筛选）-----
# 不配则 /regions 返回 500，前端三个省/市/区筛选会变灰点不动
# key 需在腾讯位置服务控制台开通「行政区划」WebServiceAPI 权限
TENCENT_MAP_KEY=
# 仅当该 key 开启了 SN 签名校验时才填；没开就留空（填了反而签名对不上）
TENCENT_MAP_SK=
