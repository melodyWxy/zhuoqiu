# ========================================================
# 桌球计分 · 部署配置
# 复制为 .env 后修改：cp .env.example .env
# ========================================================

# ----- 端口（宿主机暴露） -----
H5_PORT=8080
ADMIN_PORT=8081
API_PORT=3001

# ----- 域名（仅用于文档展示；nginx 用 default_server 不绑定具体域名） -----
# 配反向代理（如阿里云负载均衡 / Caddy）时把下面三个域名分别指向上面的端口
H5_DOMAIN=m.zhuoqiu.local
ADMIN_DOMAIN=admin.zhuoqiu.local
API_DOMAIN=api.zhuoqiu.local

# ----- PostgreSQL（容器内，无需对外暴露） -----
POSTGRES_DB=zhuoqiu
POSTGRES_USER=zhuoqiu
POSTGRES_PASSWORD=zhuoqiu_dev_change_me

# ----- JWT secrets（先 dev 默认；上线改 32+ 随机字符串） -----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- 开发模式短信 -----
# 设了就跳过真实短信通道，所有 send-sms 直接通过，verify 只接受这个值
# 上线前清空（DEV_FIXED_SMS_CODE=）让真实短信通道生效
DEV_FIXED_SMS_CODE=123456

# ----- 默认平台超级管理员（首次启动 seed 时创建） -----
SEED_SUPER_ADMIN_USERNAME=admin
SEED_SUPER_ADMIN_PASSWORD=Admin@123456
SEED_SUPER_ADMIN_NAME=超级管理员

# ----- 默认开发用商家账号 -----
SEED_DEV_VENUE_PHONE=13900000001
